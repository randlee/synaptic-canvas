use std::fs;
use std::path::PathBuf;

use serde::{Deserialize, Serialize};

use crate::backend::DeviceBackend;
use crate::contracts::{
    CliError,
    DeviceState,
    GetDeviceRequest,
    SetDeviceModeRequest,
    SetDeviceModeResponse,
};

#[derive(Debug, Serialize, Deserialize)]
struct PersistedState {
    device_id: String,
    current_mode: String,
    status: String,
}

#[derive(Debug, Serialize, Deserialize, Default)]
struct SimulatorControls {
    #[serde(default)]
    fail_reads: bool,
    #[serde(default)]
    fail_writes: bool,
    forced_status: Option<String>,
}

impl Default for PersistedState {
    fn default() -> Self {
        Self {
            device_id: "{{ device_id }}".to_string(),
            current_mode: "idle".to_string(),
            status: "ready".to_string(),
        }
    }
}

pub struct FileBackedSimulator {
    state_path: PathBuf,
}

impl FileBackedSimulator {
    pub fn new(state_path: PathBuf) -> Self {
        Self { state_path }
    }

    fn load_state(&self) -> Result<PersistedState, CliError> {
        let controls = self.load_controls()?;
        if controls.fail_reads {
            return Err(CliError {
                code: "backend.unavailable".to_string(),
                category: "dependency".to_string(),
                message: "Simulator read path is configured to fail.".to_string(),
                remediation: "Clear the controls file or disable fail_reads.".to_string(),
            });
        }

        if !self.state_path.exists() {
            let state = PersistedState::default();
            self.save_state(&state)?;
            return Ok(state);
        }

        let raw = fs::read_to_string(&self.state_path).map_err(|error| CliError {
            code: "simulator.read_failed".to_string(),
            category: "backend".to_string(),
            message: format!("failed to read simulator state: {error}"),
            remediation: "Verify the state file path is writable and readable.".to_string(),
        })?;

        serde_json::from_str(&raw).map_err(|error| CliError {
            code: "simulator.invalid_state".to_string(),
            category: "backend".to_string(),
            message: format!("failed to parse simulator state: {error}"),
            remediation: "Delete the state file and retry to regenerate a clean simulator state.".to_string(),
        })
    }

    fn save_state(&self, state: &PersistedState) -> Result<(), CliError> {
        let controls = self.load_controls()?;
        if controls.fail_writes {
            return Err(CliError {
                code: "backend.unavailable".to_string(),
                category: "dependency".to_string(),
                message: "Simulator write path is configured to fail.".to_string(),
                remediation: "Clear the controls file or disable fail_writes.".to_string(),
            });
        }

        if let Some(parent) = self.state_path.parent() {
            fs::create_dir_all(parent).map_err(|error| CliError {
                code: "simulator.mkdir_failed".to_string(),
                category: "backend".to_string(),
                message: format!("failed to create simulator directory: {error}"),
                remediation: "Verify the output directory exists and is writable.".to_string(),
            })?;
        }

        let raw = serde_json::to_string_pretty(state).map_err(|error| CliError {
            code: "simulator.serialize_failed".to_string(),
            category: "backend".to_string(),
            message: format!("failed to serialize simulator state: {error}"),
            remediation: "Inspect the state model and ensure it remains serializable.".to_string(),
        })?;

        fs::write(&self.state_path, raw).map_err(|error| CliError {
            code: "simulator.write_failed".to_string(),
            category: "backend".to_string(),
            message: format!("failed to write simulator state: {error}"),
            remediation: "Verify the state file path is writable.".to_string(),
        })
    }

    fn load_controls(&self) -> Result<SimulatorControls, CliError> {
        let control_path = PathBuf::from(format!("{}.controls.json", self.state_path.display()));
        if !control_path.exists() {
            return Ok(SimulatorControls::default());
        }

        let raw = fs::read_to_string(&control_path).map_err(|error| CliError {
            code: "simulator.invalid_controls".to_string(),
            category: "backend".to_string(),
            message: format!("failed to read simulator controls: {error}"),
            remediation: "Delete or repair the controls file and retry.".to_string(),
        })?;

        serde_json::from_str(&raw).map_err(|error| CliError {
            code: "simulator.invalid_controls".to_string(),
            category: "backend".to_string(),
            message: format!("failed to parse simulator controls: {error}"),
            remediation: "Delete or repair the controls file and retry.".to_string(),
        })
    }

    fn apply_status_override(status: String, controls: &SimulatorControls) -> String {
        controls
            .forced_status
            .clone()
            .unwrap_or(status)
    }

    fn validate_mode(mode: &str) -> Result<(), CliError> {
        match mode {
            "idle" | "active" => Ok(()),
            other => Err(CliError {
                code: "validation.invalid_mode".to_string(),
                category: "validation".to_string(),
                message: format!("unsupported mode '{other}'"),
                remediation: "Use one of: idle, active.".to_string(),
            }),
        }
    }
}

impl DeviceBackend for FileBackedSimulator {
    fn set_device_mode(&mut self, request: SetDeviceModeRequest) -> Result<SetDeviceModeResponse, CliError> {
        Self::validate_mode(&request.mode)?;
        let mut state = self.load_state()?;
        state.current_mode = request.mode.clone();
        state.status = "updated".to_string();
        self.save_state(&state)?;
        let controls = self.load_controls()?;

        Ok(SetDeviceModeResponse {
            device_id: state.device_id,
            requested_mode: request.mode.clone(),
            applied_mode: request.mode,
            status: Self::apply_status_override(state.status, &controls),
            diagnostic_code: "mode.updated".to_string(),
        })
    }

    fn get_device(&self, _request: GetDeviceRequest) -> Result<DeviceState, CliError> {
        let state = self.load_state()?;
        let controls = self.load_controls()?;
        Ok(DeviceState {
            device_id: state.device_id,
            current_mode: state.current_mode,
            status: Self::apply_status_override(state.status, &controls),
        })
    }
}
